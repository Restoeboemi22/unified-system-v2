# Environment Docker Compose untuk VPS production
# Salin file ini menjadi `.env` di server VPS, lalu isi kredensial yang sebenarnya.

NODE_ENV=production

# Firebase Admin untuk tenant-school-service
FIREBASE_PROJECT_ID=smpn3pacet-app
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@smpn3pacet-app.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nISI_PRIVATE_KEY_LENGKAP_DI_SINI\n-----END PRIVATE KEY-----\n"

# Alternatif jika ingin memakai file service account JSON di VPS:
# FIREBASE_SERVICE_ACCOUNT_PATH=/root/unified-system-v2/secrets/firebase-service-account.json
# GOOGLE_APPLICATION_CREDENTIALS=/root/unified-system-v2/secrets/firebase-service-account.json
