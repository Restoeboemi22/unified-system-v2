# Environment Docker Compose untuk VPS production
# Salin file ini menjadi `.env` di server VPS.
# Rekomendasi production: gunakan file service account JSON yang di-mount read-only ke container.

NODE_ENV=production

# Firebase Admin untuk tenant-school-service
FIREBASE_PROJECT_ID=smpn3pacet-app
FIREBASE_SERVICE_ACCOUNT_PATH=/app/secrets/firebase-service-account.json
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/firebase-service-account.json

# Alternatif jika tidak memakai file JSON, isi 2 variabel berikut:
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@smpn3pacet-app.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nISI_PRIVATE_KEY_LENGKAP_DI_SINI\n-----END PRIVATE KEY-----\n"
