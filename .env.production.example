# ==============================================================
# ENVIRONMENT VARIABLES UNTUK PRODUCTION (BACKEND MICROSERVICES)
# ==============================================================

# Port internal untuk masing-masing service (Platform Cloud biasanya mengisi ini otomatis via $PORT)
PORT=3000

# Kredensial Database PostgreSQL (Supabase/Neon/Self-hosted)
# Ganti dengan connection string dari provider database Anda
DATABASE_URL="postgresql://user:password@host:port/db_name?sslmode=require"

# Base URL untuk Komunikasi Antar-Microservice
# Ketika di-deploy, masing-masing service akan mendapatkan URL publik/internal dari cloud provider.
# Masukkan URL dari masing-masing service di sini:
SESSION_SERVICE_BASE_URL="https://session-service-url.up.railway.app"
POLICY_SERVICE_BASE_URL="https://policy-service-url.up.railway.app"
TENANT_SCHOOL_SERVICE_BASE_URL="https://tenant-school-service-url.up.railway.app"
ACADEMIC_DIRECTORY_SERVICE_BASE_URL="https://academic-directory-service-url.up.railway.app"
ATTENDANCE_SERVICE_BASE_URL="https://attendance-service-url.up.railway.app"

# Kredensial Firebase Admin (Wajib untuk validasi token autentikasi)
# Dapatkan nilai ini dari Firebase Console -> Project Settings -> Service Accounts -> Generate New Private Key
FIREBASE_PROJECT_ID="smpn3pacet-app"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@smpn3pacet-app.iam.gserviceaccount.com"
# Perhatikan format private key, harus berupa string lengkap dengan \n (newline)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIB... (salin utuh) ...T8=\n-----END PRIVATE KEY-----\n"

# ==============================================================
# ENVIRONMENT VARIABLES UNTUK FRONTEND (VERCEL / FIREBASE HOSTING)
# ==============================================================
# Gunakan prefix VITE_ agar variabel ini terbaca di aplikasi web-admin saat build time

VITE_SESSION_SERVICE_URL="https://session-service-url.up.railway.app"
VITE_POLICY_SERVICE_URL="https://policy-service-url.up.railway.app"
VITE_TENANT_SCHOOL_SERVICE_URL="https://tenant-school-service-url.up.railway.app"
VITE_ACADEMIC_DIRECTORY_SERVICE_URL="https://academic-directory-service-url.up.railway.app"
VITE_ATTENDANCE_SERVICE_URL="https://attendance-service-url.up.railway.app"
